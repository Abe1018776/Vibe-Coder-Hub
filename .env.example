# Supabase (client-side keys — safe to expose, NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# App base URL — used for OAuth redirects. Set to your domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google sign-in is configured in the Supabase dashboard, not here.
# See docs/GOOGLE_OAUTH_SETUP.md.
